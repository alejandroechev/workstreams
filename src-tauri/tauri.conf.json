{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workstreams",
  "version": "0.2.0",
  "identifier": "com.alejandroe.workstreams",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5177",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workstreams",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "maximized": true,
        "additionalBrowserArgs": "--remote-debugging-port=9222"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
